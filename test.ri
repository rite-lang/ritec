struct Vec<'a>
    ptr: *mut 'a
    len: usize
    cap: usize

impl Vec<'a>
    pub fn new() -> Self
        Self
            ptr: null
            len: 0
            cap: 0 

struct VTable
    func: fn(i32) -> i32

fn foo(x: i32) -> i32
    x + 3

fn main(argc: usize, argv: **u8) -> usize
    let vtable = VTable
        func: foo

    (vtable.func)(4) as usize
